    const trimmed = value.trim();
    if (!trimmed) return;
    setSettings((prev) => ({ ...prev, [key]: [...prev[key], trimmed] }));
    setter('');
  };

  const removeListItem = (key, item) => {
    setSettings((prev) => ({ ...prev, [key]: prev[key].filter((entry) => entry !== item) }));
  };

