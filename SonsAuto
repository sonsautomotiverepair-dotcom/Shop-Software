                          <div className="flex items-center justify-between gap-3">
                            <div>
                              <div className="font-semibold">{order.ro}</div>
                              <div className={`text-sm ${selectedOrderId === order.id ? 'text-slate-300' : 'text-slate-500'}`}>{customer?.name}</div>
                            </div>
                            <Badge variant={selectedOrderId === order.id ? 'outline' : 'secondary'} className="rounded-xl">{order.status}</Badge>
                          </div>
