export default function ShopManagementMVP() {
  const defaultSettings = {
    shopName: 'Sons Auto Repair',
    systemName: 'Sons Auto Repair Shop System',
    laborRate: 126,
    techCount: 4,
    payStructure: 'Flag Hours',
    estimateDelivery: 'Both',
    statuses: [
      'Waiting for Diagnosis',
      'Waiting on Parts',
      'Waiting for Approval',
      'In Progress',
      'Ready For Pickup',
      'Closed',
    ],
    vendors: ['AutoZone', 'O’Reilly’s', 'RockAuto'],
    shopSuppliesEnabled: true,
    shopSuppliesPercent: 8,
    taxEnabled: true,
    taxPercent: 0,
    productivityTracking: true,
    techs: ['Johnny', 'Cody', 'Luis', 'Tyler'],
    advisors: ['Johnny'],
  };

  const [settings, setSettings] = useState(defaultSettings);
  const [customers, setCustomers] = useState(initialCustomers);
  const [vehicles, setVehicles] = useState(initialVehicles);
  const [orders, setOrders] = useState(initialOrders);
  const [search, setSearch] = useState('');
  const [selectedOrderId, setSelectedOrderId] = useState(initialOrders[0].id);
  const [newVendor, setNewVendor] = useState('');
  const [newStatus, setNewStatus] = useState('');
  const [newTech, setNewTech] = useState('');
  const [newAdvisor, setNewAdvisor] = useState('');
  const [newPart, setNewPart] = useState({ partNumber: '', description: '', qty: 1, price: 0, vendor: 'AutoZone' });
  const [newLabor, setNewLabor] = useState({ description: '', hours: 1, rate: defaultSettings.laborRate });
  const [newCustomer, setNewCustomer] = useState({ name: '', phone: '', email: '' });
  const [newVehicle, setNewVehicle] = useState({ customerId: '', year: '', make: '', model: '', vin: '', plate: '', mileage: '' });
  const [newRO, setNewRO] = useState({ customerId: '', vehicleId: '', complaint: '', advisor: 'Johnny', tech: 'Cody' });

  const selectedOrder = useMemo(() => orders.find((o) => o.id === selectedOrderId) || orders[0], [orders, selectedOrderId]);

  const filteredOrders = useMemo(() => {
    const q = search.toLowerCase().trim();
    if (!q) return orders;
    return orders.filter((order) => {
      const customer = customers.find((c) => c.id === order.customerId);
      const vehicle = vehicles.find((v) => v.id === order.vehicleId);
      const haystack = [order.ro, order.status, order.complaint, customer?.name, vehicle?.make, vehicle?.model, vehicle?.plate, vehicle?.vin].join(' ').toLowerCase();
      return haystack.includes(q);
    });
  }, [orders, customers, vehicles, search]);

  const calcShopSupplies = (order) => settings.shopSuppliesEnabled ? calcGrandTotal(order) * (Number(settings.shopSuppliesPercent || 0) / 100) : 0;
  const calcTax = (order) => settings.taxEnabled ? (calcGrandTotal(order) + calcShopSupplies(order)) * (Number(settings.taxPercent || 0) / 100) : 0;
  const calcInvoiceTotal = (order) => calcGrandTotal(order) + calcShopSupplies(order) + calcTax(order);

  const kpis = useMemo(() => {
    const open = orders.filter((o) => o.status !== 'Ready For Pickup' && o.status !== 'Closed').length;
    const ready = orders.filter((o) => o.status === 'Ready For Pickup').length;
    const sales = orders.reduce((sum, o) => sum + calcInvoiceTotal(o), 0);
    const awaiting = orders.filter((o) => o.status === 'Waiting for Approval' || o.status === 'Awaiting Approval').length;
    return { open, ready, sales, awaiting };
  }, [orders, settings]);

  const productivity = useMemo(() => {
    return settings.techs.map((tech) => {
      const techOrders = orders.filter((o) => o.tech === tech);
      const flaggedHours = techOrders.reduce((sum, order) => sum + order.labor.reduce((laborSum, line) => laborSum + Number(line.hours || 0), 0), 0);
      const sales = techOrders.reduce((sum, order) => sum + calcInvoiceTotal(order), 0);
      return { tech, ros: techOrders.length, flaggedHours, sales };
    });
  }, [orders, settings]);

  const getCustomer = (id) => customers.find((c) => c.id === id);
  const getVehicle = (id) => vehicles.find((v) => v.id === id);

  const addPartToOrder = () => {
    if (!selectedOrder || !newPart.description) return;
    setOrders((prev) => prev.map((order) => order.id === selectedOrder.id ? {
      ...order,
      parts: [...order.parts, { id: Date.now(), partNumber: newPart.partNumber || 'CUSTOM', description: newPart.description, qty: Number(newPart.qty), price: Number(newPart.price), vendor: newPart.vendor }],
    } : order));
    setNewPart({ partNumber: '', description: '', qty: 1, price: 0, vendor: settings.vendors[0] || 'AutoZone' });
  };

  const addLaborToOrder = () => {
    if (!selectedOrder || !newLabor.description) return;
    setOrders((prev) => prev.map((order) => order.id === selectedOrder.id ? {
      ...order,
      labor: [...order.labor, { id: Date.now(), description: newLabor.description, hours: Number(newLabor.hours), rate: Number(newLabor.rate) }],
    } : order));
    setNewLabor({ description: '', hours: 1, rate: Number(settings.laborRate) || 126 });
  };

  const updateOrderStatus = (status) => {
    if (!selectedOrder) return;
    setOrders((prev) => prev.map((order) => (order.id === selectedOrder.id ? { ...order, status } : order)));
  };

  const closeAndPayInvoice = () => {
    if (!selectedOrder) return;
    setOrders((prev) => prev.map((order) => (order.id === selectedOrder.id ? { ...order, status: 'Closed', invoicePaid: true } : order)));
  };

  const createCustomer = () => {
    if (!newCustomer.name) return;
    const customer = { id: Date.now(), ...newCustomer, vehicles: [] };
    setCustomers((prev) => [customer, ...prev]);
    setNewCustomer({ name: '', phone: '', email: '' });
  };

  const createVehicle = () => {
    if (!newVehicle.customerId || !newVehicle.make || !newVehicle.model) return;
    const vehicle = { id: Date.now(), customerId: Number(newVehicle.customerId), year: Number(newVehicle.year) || new Date().getFullYear(), make: newVehicle.make, model: newVehicle.model, vin: newVehicle.vin, plate: newVehicle.plate, mileage: Number(newVehicle.mileage) || 0 };
    setVehicles((prev) => [vehicle, ...prev]);
    setCustomers((prev) => prev.map((c) => (c.id === vehicle.customerId ? { ...c, vehicles: [...c.vehicles, vehicle.id] } : c)));
    setNewVehicle({ customerId: '', year: '', make: '', model: '', vin: '', plate: '', mileage: '' });
  };

  const createRepairOrder = () => {
    if (!newRO.customerId || !newRO.vehicleId || !newRO.complaint) return;
