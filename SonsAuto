                    <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
                      <div className="space-y-3">
                        <div className="flex items-center justify-between"><h3 className="font-semibold text-lg">Labor Lines</h3><Badge variant="secondary" className="rounded-xl">{currency(calcLaborTotal(selectedOrder.labor))}</Badge></div>
                        <Table>
                          <TableHeader><TableRow><TableHead>Description</TableHead><TableHead>Hours</TableHead><TableHead>Rate</TableHead><TableHead>Total</TableHead></TableRow></TableHeader>
                          <TableBody>
                            {selectedOrder.labor.map((item) => (
                              <TableRow key={item.id}><TableCell>{item.description}</TableCell><TableCell>{item.hours}</TableCell><TableCell>{currency(item.rate)}</TableCell><TableCell>{currency(item.hours * item.rate)}</TableCell></TableRow>
                            ))}
                          </TableBody>
                        </Table>
                        <div className="rounded-2xl border p-4 space-y-3 bg-slate-50">
                          <div className="font-medium">Add Labor</div>
                          <Input placeholder="Description" value={newLabor.description} onChange={(e) => setNewLabor((s) => ({ ...s, description: e.target.value }))} />
                          <div className="grid grid-cols-2 gap-3">
                            <Input type="number" placeholder="Hours" value={newLabor.hours} onChange={(e) => setNewLabor((s) => ({ ...s, hours: e.target.value }))} />
                            <Input type="number" placeholder="Rate" value={newLabor.rate} onChange={(e) => setNewLabor((s) => ({ ...s, rate: e.target.value }))} />
                          </div>
                          <Button onClick={addLaborToOrder} className="rounded-2xl w-full">Add Labor Line</Button>
                        </div>
                      </div>

                      <div className="space-y-3">
                        <div className="flex items-center justify-between"><h3 className="font-semibold text-lg">Parts Lines</h3><Badge variant="secondary" className="rounded-xl">{currency(calcPartsTotal(selectedOrder.parts))}</Badge></div>
                        <Table>
                          <TableHeader><TableRow><TableHead>Part</TableHead><TableHead>Qty</TableHead><TableHead>Price</TableHead><TableHead>Vendor</TableHead></TableRow></TableHeader>
                          <TableBody>
                            {selectedOrder.parts.map((item) => (
                              <TableRow key={item.id}><TableCell><div className="font-medium">{item.description}</div><div className="text-xs text-slate-500">{item.partNumber}</div></TableCell><TableCell>{item.qty}</TableCell><TableCell>{currency(item.price)}</TableCell><TableCell>{item.vendor}</TableCell></TableRow>
                            ))}
                          </TableBody>
                        </Table>
                        <div className="rounded-2xl border p-4 space-y-3 bg-slate-50">
                          <div className="font-medium">Add / Order Part</div>
                          <div className="grid grid-cols-2 gap-3">
                            <Input placeholder="Part #" value={newPart.partNumber} onChange={(e) => setNewPart((s) => ({ ...s, partNumber: e.target.value }))} />
                            <Select value={newPart.vendor} onValueChange={(value) => setNewPart((s) => ({ ...s, vendor: value }))}>
                              <SelectTrigger><SelectValue placeholder="Vendor" /></SelectTrigger>
                              <SelectContent>
                                {settings.vendors.map((vendor) => <SelectItem key={vendor} value={vendor}>{vendor}</SelectItem>)}
                              </SelectContent>
                            </Select>
                          </div>
                          <Input placeholder="Description" value={newPart.description} onChange={(e) => setNewPart((s) => ({ ...s, description: e.target.value }))} />
                          <div className="grid grid-cols-2 gap-3">
                            <Input type="number" placeholder="Qty" value={newPart.qty} onChange={(e) => setNewPart((s) => ({ ...s, qty: e.target.value }))} />
                            <Input type="number" placeholder="Unit Price" value={newPart.price} onChange={(e) => setNewPart((s) => ({ ...s, price: e.target.value }))} />
                          </div>
                          <Button onClick={addPartToOrder} className="rounded-2xl w-full">Add Part To Ticket</Button>
                        </div>
                      </div>
                    </div>

                    <div className="rounded-2xl border p-4 bg-slate-50">
                      <div className="font-medium mb-2">Notes</div>
                      <Textarea value={selectedOrder.notes} onChange={(e) => setOrders((prev) => prev.map((o) => (o.id === selectedOrder.id ? { ...o, notes: e.target.value } : o)))} className="min-h-[100px]" />
                    </div>
                  </CardContent>
                </Card>
              )}
            </div>
          </TabsContent>

          <TabsContent value="invoicing">
            {selectedOrder && (
              <Card className="rounded-2xl shadow-sm">
                <CardHeader>
                  <div className="flex flex-col md:flex-row md:items-center md:justify-between gap-3">
                    <div>
                      <CardTitle>Invoice Preview</CardTitle>
                      <CardDescription>{selectedOrder.ro} • {getCustomer(selectedOrder.customerId)?.name} • estimates by {settings.estimateDelivery.toLowerCase()}</CardDescription>
                    </div>
                    <div className="flex gap-2 flex-wrap">
                      <Button variant="outline" className="rounded-2xl" onClick={() => window.print()}>Print Invoice</Button>
                      <Button className="rounded-2xl" onClick={closeAndPayInvoice}>Mark Paid</Button>
                    </div>
                  </div>
                </CardHeader>
                <CardContent className="space-y-6">
                  <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                      <h3 className="font-semibold text-lg">{settings.shopName}</h3>
                      <p className="text-slate-600">Repair order and invoice summary</p>
                    </div>
                    <div className="text-sm text-slate-600 md:text-right">
                      <p><span className="font-medium text-slate-900">Customer:</span> {getCustomer(selectedOrder.customerId)?.name}</p>
                      <p><span className="font-medium text-slate-900">Phone:</span> {getCustomer(selectedOrder.customerId)?.phone}</p>
                      <p><span className="font-medium text-slate-900">Vehicle:</span> {getVehicle(selectedOrder.vehicleId)?.year} {getVehicle(selectedOrder.vehicleId)?.make} {getVehicle(selectedOrder.vehicleId)?.model}</p>
                      <p><span className="font-medium text-slate-900">RO:</span> {selectedOrder.ro}</p>
                    </div>
                  </div>

                  <Separator />

                  <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
                    <div>
                      <h4 className="font-semibold mb-3">Labor</h4>
                      <Table>
                        <TableHeader><TableRow><TableHead>Description</TableHead><TableHead>Hours</TableHead><TableHead>Total</TableHead></TableRow></TableHeader>
                        <TableBody>
                          {selectedOrder.labor.map((item) => <TableRow key={item.id}><TableCell>{item.description}</TableCell><TableCell>{item.hours}</TableCell><TableCell>{currency(item.hours * item.rate)}</TableCell></TableRow>)}
                        </TableBody>
                      </Table>
                    </div>
                    <div>
                      <h4 className="font-semibold mb-3">Parts</h4>
                      <Table>
                        <TableHeader><TableRow><TableHead>Description</TableHead><TableHead>Qty</TableHead><TableHead>Total</TableHead></TableRow></TableHeader>
                        <TableBody>
                          {selectedOrder.parts.map((item) => <TableRow key={item.id}><TableCell>{item.description}</TableCell><TableCell>{item.qty}</TableCell><TableCell>{currency(item.qty * item.price)}</TableCell></TableRow>)}
                        </TableBody>
                      </Table>
                    </div>
                  </div>

                  <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <Card className="rounded-2xl border-slate-200">
                      <CardContent className="p-4 space-y-2 text-sm">
                        <div className="flex justify-between"><span>Labor Total</span><span>{currency(calcLaborTotal(selectedOrder.labor))}</span></div>
                        <div className="flex justify-between"><span>Parts Total</span><span>{currency(calcPartsTotal(selectedOrder.parts))}</span></div>
                        <div className="flex justify-between"><span>Shop Supplies</span><span>{currency(calcShopSupplies(selectedOrder))}</span></div>
                        <div className="flex justify-between"><span>Tax</span><span>{currency(calcTax(selectedOrder))}</span></div>
                        <Separator />
                        <div className="flex justify-between text-lg font-semibold"><span>Total Due</span><span>{currency(calcInvoiceTotal(selectedOrder))}</span></div>
                      </CardContent>
                    </Card>
                    <Card className="rounded-2xl border-slate-200">
                      <CardContent className="p-4 space-y-2 text-sm">
                        <div className="font-semibold">Invoice Notes</div>
                        <p className="text-slate-600">{selectedOrder.notes || 'No invoice notes added.'}</p>
                        <div className="pt-2"><Badge className="rounded-xl">{selectedOrder.invoicePaid ? 'Paid' : 'Unpaid'}</Badge></div>
                      </CardContent>
                    </Card>
                  </div>
                </CardContent>
              </Card>
            )}
          </TabsContent>

          <TabsContent value="parts">
            <div className="grid grid-cols-1 xl:grid-cols-3 gap-4">
              <Card className="xl:col-span-2 rounded-2xl shadow-sm">
                <CardHeader>
                  <CardTitle>Parts Ordering Center</CardTitle>
                  <CardDescription>Preferred vendors and pricing behavior can be edited in Settings.</CardDescription>
                </CardHeader>
                <CardContent>
                  <Table>
                    <TableHeader><TableRow><TableHead>RO</TableHead><TableHead>Part #</TableHead><TableHead>Description</TableHead><TableHead>Vendor</TableHead><TableHead>Qty</TableHead><TableHead>Price</TableHead></TableRow></TableHeader>
                    <TableBody>
                      {orders.flatMap((order) => order.parts.map((part) => ({ ...part, ro: order.ro }))).map((part, idx) => (
                        <TableRow key={`${part.id}-${idx}`}><TableCell>{part.ro}</TableCell><TableCell>{part.partNumber}</TableCell><TableCell>{part.description}</TableCell><TableCell>{part.vendor}</TableCell><TableCell>{part.qty}</TableCell><TableCell>{currency(part.price)}</TableCell></TableRow>
                      ))}
                    </TableBody>
                  </Table>
                </CardContent>
              </Card>
              <Card className="rounded-2xl shadow-sm">
                <CardHeader>
                  <CardTitle>Vendor Integrations</CardTitle>
                  <CardDescription>Edit the vendor list anytime for your shop.</CardDescription>
                </CardHeader>
                <CardContent className="space-y-3 text-sm text-slate-600">
                  {settings.vendors.map((vendor) => (
                    <div key={vendor} className="p-4 rounded-2xl border bg-slate-50 flex items-center justify-between gap-3">
                      <div>
                        <div className="font-medium text-slate-900 flex items-center gap-2"><ShoppingCart className="h-4 w-4" />{vendor}</div>
                        <p className="mt-1">Available as a preferred supplier for parts entry and future ordering.</p>
                      </div>
                      <Button variant="outline" className="rounded-xl" onClick={() => removeListItem('vendors', vendor)}>Remove</Button>
                    </div>
                  ))}
                </CardContent>
              </Card>
            </div>
          </TabsContent>

          <TabsContent value="crm">
            <div className="grid grid-cols-1 xl:grid-cols-3 gap-4">
              <Card className="rounded-2xl shadow-sm">
                <CardHeader><CardTitle>Add Customer</CardTitle><CardDescription>Create a new customer profile.</CardDescription></CardHeader>
                <CardContent className="space-y-3">
                  <Input placeholder="Customer name" value={newCustomer.name} onChange={(e) => setNewCustomer((s) => ({ ...s, name: e.target.value }))} />
                  <Input placeholder="Phone" value={newCustomer.phone} onChange={(e) => setNewCustomer((s) => ({ ...s, phone: e.target.value }))} />
                  <Input placeholder="Email" value={newCustomer.email} onChange={(e) => setNewCustomer((s) => ({ ...s, email: e.target.value }))} />
                  <Button onClick={createCustomer} className="w-full rounded-2xl">Save Customer</Button>
                </CardContent>
              </Card>
              <Card className="rounded-2xl shadow-sm">
                <CardHeader><CardTitle>Add Vehicle</CardTitle><CardDescription>Attach a vehicle to a customer.</CardDescription></CardHeader>
                <CardContent className="space-y-3">
                  <Select value={String(newVehicle.customerId)} onValueChange={(v) => setNewVehicle((s) => ({ ...s, customerId: v }))}>
                    <SelectTrigger><SelectValue placeholder="Choose customer" /></SelectTrigger>
                    <SelectContent>{customers.map((c) => <SelectItem key={c.id} value={String(c.id)}>{c.name}</SelectItem>)}</SelectContent>
                  </Select>
                  <div className="grid grid-cols-3 gap-2">
                    <Input placeholder="Year" value={newVehicle.year} onChange={(e) => setNewVehicle((s) => ({ ...s, year: e.target.value }))} />
                    <Input placeholder="Make" value={newVehicle.make} onChange={(e) => setNewVehicle((s) => ({ ...s, make: e.target.value }))} />
                    <Input placeholder="Model" value={newVehicle.model} onChange={(e) => setNewVehicle((s) => ({ ...s, model: e.target.value }))} />
                  </div>
                  <Input placeholder="VIN" value={newVehicle.vin} onChange={(e) => setNewVehicle((s) => ({ ...s, vin: e.target.value }))} />
                  <div className="grid grid-cols-2 gap-2">
                    <Input placeholder="Plate" value={newVehicle.plate} onChange={(e) => setNewVehicle((s) => ({ ...s, plate: e.target.value }))} />
                    <Input placeholder="Mileage" value={newVehicle.mileage} onChange={(e) => setNewVehicle((s) => ({ ...s, mileage: e.target.value }))} />
                  </div>
                  <Button onClick={createVehicle} className="w-full rounded-2xl">Save Vehicle</Button>
                </CardContent>
              </Card>
              <Card className="rounded-2xl shadow-sm">
                <CardHeader><CardTitle>Customer List</CardTitle><CardDescription>Quick CRM view.</CardDescription></CardHeader>
                <CardContent className="space-y-3 max-h-[500px] overflow-auto">
                  {customers.map((customer) => {
                    const customerVehicles = vehicles.filter((v) => v.customerId === customer.id);
                    return (
                      <div key={customer.id} className="rounded-2xl border p-4">
                        <div className="flex items-start justify-between gap-3">
                          <div>
                            <div className="font-semibold flex items-center gap-2"><User className="h-4 w-4" />{customer.name}</div>
                            <div className="text-sm text-slate-600 mt-1">{customer.phone}</div>
                            <div className="text-sm text-slate-500">{customer.email}</div>
                          </div>
                          <Badge variant="secondary" className="rounded-xl">{customerVehicles.length} vehicles</Badge>
                        </div>
                        <div className="mt-3 space-y-1 text-sm text-slate-700">{customerVehicles.map((v) => <div key={v.id} className="flex items-center gap-2"><Car className="h-4 w-4" /><VehicleLabel vehicle={v} /></div>)}</div>
                      </div>
                    );
                  })}
                </CardContent>
              </Card>
            </div>
          </TabsContent>

          <TabsContent value="settings">
            <div className="grid grid-cols-1 xl:grid-cols-3 gap-4">
              <Card className="xl:col-span-2 rounded-2xl shadow-sm">
                <CardHeader>
                  <CardTitle>Shop Settings</CardTitle>
                  <CardDescription>Edit the operational rules of your shop inside the software.</CardDescription>
                </CardHeader>
                <CardContent className="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <div><Label>Shop Name</Label><Input value={settings.shopName} onChange={(e) => setSettings((s) => ({ ...s, shopName: e.target.value }))} /></div>
                  <div><Label>System Name</Label><Input value={settings.systemName} onChange={(e) => setSettings((s) => ({ ...s, systemName: e.target.value }))} /></div>
                  <div><Label>Labor Rate</Label><Input type="number" value={settings.laborRate} onChange={(e) => setSettings((s) => ({ ...s, laborRate: Number(e.target.value) }))} /></div>
                  <div><Label>Tech Count</Label><Input type="number" value={settings.techCount} onChange={(e) => setSettings((s) => ({ ...s, techCount: Number(e.target.value) }))} /></div>
                  <div><Label>Pay Structure</Label><Input value={settings.payStructure} onChange={(e) => setSettings((s) => ({ ...s, payStructure: e.target.value }))} /></div>
                  <div><Label>Estimate Delivery</Label><Select value={settings.estimateDelivery} onValueChange={(value) => setSettings((s) => ({ ...s, estimateDelivery: value }))}><SelectTrigger><SelectValue /></SelectTrigger><SelectContent><SelectItem value="Text">Text</SelectItem><SelectItem value="Email">Email</SelectItem><SelectItem value="Both">Both</SelectItem></SelectContent></Select></div>
                  <div><Label>Shop Supplies %</Label><Input type="number" value={settings.shopSuppliesPercent} onChange={(e) => setSettings((s) => ({ ...s, shopSuppliesPercent: Number(e.target.value) }))} /></div>
                  <div><Label>Tax %</Label><Input type="number" value={settings.taxPercent} onChange={(e) => setSettings((s) => ({ ...s, taxPercent: Number(e.target.value) }))} /></div>
                  <div className="flex items-center justify-between rounded-2xl border p-4"><div><div className="font-medium">Shop Supplies Enabled</div><div className="text-sm text-slate-500">Apply a configurable fee to invoices.</div></div><Button variant={settings.shopSuppliesEnabled ? 'default' : 'outline'} onClick={() => setSettings((s) => ({ ...s, shopSuppliesEnabled: !s.shopSuppliesEnabled }))}>{settings.shopSuppliesEnabled ? 'On' : 'Off'}</Button></div>
                  <div className="flex items-center justify-between rounded-2xl border p-4"><div><div className="font-medium">Productivity Tracking</div><div className="text-sm text-slate-500">Show flag-hour performance on the dashboard.</div></div><Button variant={settings.productivityTracking ? 'default' : 'outline'} onClick={() => setSettings((s) => ({ ...s, productivityTracking: !s.productivityTracking }))}>{settings.productivityTracking ? 'On' : 'Off'}</Button></div>
                </CardContent>
              </Card>

              <Card className="rounded-2xl shadow-sm">
                <CardHeader><CardTitle>Live Summary</CardTitle><CardDescription>What the current settings are driving.</CardDescription></CardHeader>
                <CardContent className="space-y-3 text-sm text-slate-700">
                  <div className="rounded-2xl border p-4"><div className="font-medium">{settings.techCount} techs</div><div className="text-slate-500">{settings.payStructure} workflow</div></div>
                  <div className="rounded-2xl border p-4"><div className="font-medium">${settings.laborRate}/hr labor rate</div><div className="text-slate-500">Default rate for new labor lines</div></div>
                  <div className="rounded-2xl border p-4"><div className="font-medium">Estimates by {settings.estimateDelivery.toLowerCase()}</div><div className="text-slate-500">Customer communication preference</div></div>
                  <div className="rounded-2xl border p-4"><div className="font-medium">{settings.vendors.length} preferred vendors</div><div className="text-slate-500">{settings.vendors.join(', ')}</div></div>
                </CardContent>
              </Card>
            </div>

            <div className="grid grid-cols-1 xl:grid-cols-3 gap-4 mt-4">
              <Card className="rounded-2xl shadow-sm">
                <CardHeader><CardTitle>Statuses</CardTitle><CardDescription>Add or remove workflow statuses.</CardDescription></CardHeader>
                <CardContent className="space-y-3">
                  <div className="flex gap-2"><Input placeholder="Add status" value={newStatus} onChange={(e) => setNewStatus(e.target.value)} /><Button onClick={() => addListItem('statuses', newStatus, setNewStatus)}>Add</Button></div>
                  {settings.statuses.map((status) => <div key={status} className="flex items-center justify-between rounded-xl border p-3"><span>{status}</span><Button variant="outline" size="sm" onClick={() => removeListItem('statuses', status)}>Remove</Button></div>)}
                </CardContent>
              </Card>
              <Card className="rounded-2xl shadow-sm">
                <CardHeader><CardTitle>Vendors</CardTitle><CardDescription>Edit AutoZone, O’Reilly’s, RockAuto, or add more.</CardDescription></CardHeader>
                <CardContent className="space-y-3">
                  <div className="flex gap-2"><Input placeholder="Add vendor" value={newVendor} onChange={(e) => setNewVendor(e.target.value)} /><Button onClick={() => addListItem('vendors', newVendor, setNewVendor)}>Add</Button></div>
                  {settings.vendors.map((vendor) => <div key={vendor} className="flex items-center justify-between rounded-xl border p-3"><span>{vendor}</span><Button variant="outline" size="sm" onClick={() => removeListItem('vendors', vendor)}>Remove</Button></div>)}
                </CardContent>
              </Card>
              <Card className="rounded-2xl shadow-sm">
                <CardHeader><CardTitle>Team</CardTitle><CardDescription>Edit technicians and advisors used in repair orders.</CardDescription></CardHeader>
                <CardContent className="space-y-4">
                  <div>
                    <div className="font-medium mb-2">Technicians</div>
                    <div className="flex gap-2 mb-2"><Input placeholder="Add tech" value={newTech} onChange={(e) => setNewTech(e.target.value)} /><Button onClick={() => addListItem('techs', newTech, setNewTech)}>Add</Button></div>
                    <div className="space-y-2">{settings.techs.map((tech) => <div key={tech} className="flex items-center justify-between rounded-xl border p-3"><span>{tech}</span><Button variant="outline" size="sm" onClick={() => removeListItem('techs', tech)}>Remove</Button></div>)}</div>
                  </div>
                  <div>
                    <div className="font-medium mb-2">Advisors</div>
                    <div className="flex gap-2 mb-2"><Input placeholder="Add advisor" value={newAdvisor} onChange={(e) => setNewAdvisor(e.target.value)} /><Button onClick={() => addListItem('advisors', newAdvisor, setNewAdvisor)}>Add</Button></div>
                    <div className="space-y-2">{settings.advisors.map((advisor) => <div key={advisor} className="flex items-center justify-between rounded-xl border p-3"><span>{advisor}</span><Button variant="outline" size="sm" onClick={() => removeListItem('advisors', advisor)}>Remove</Button></div>)}</div>
                  </div>
                </CardContent>
              </Card>
            </div>
          </TabsContent>
        </Tabs>
      </div>
    </div>
  );
}
