                <CardContent>
                  <Table>
                    <TableHeader>
                      <TableRow>
                        <TableHead>RO</TableHead>
                        <TableHead>Customer</TableHead>
                        <TableHead>Vehicle</TableHead>
                        <TableHead>Status</TableHead>
                        <TableHead>Total</TableHead>
                      </TableRow>
                    </TableHeader>
                    <TableBody>
                      {orders.map((order) => {
                        const customer = getCustomer(order.customerId);
                        const vehicle = getVehicle(order.vehicleId);
                        return (
                          <TableRow key={order.id} className="cursor-pointer" onClick={() => setSelectedOrderId(order.id)}>
                            <TableCell className="font-medium">{order.ro}</TableCell>
                            <TableCell>{customer?.name}</TableCell>
                            <TableCell>{vehicle?.year} {vehicle?.make} {vehicle?.model}</TableCell>
                            <TableCell><Badge variant="secondary" className="rounded-xl">{order.status}</Badge></TableCell>
                            <TableCell>{currency(calcInvoiceTotal(order))}</TableCell>
                          </TableRow>
                        );
                      })}
                    </TableBody>
                  </Table>
                </CardContent>
              </Card>

              <Card className="rounded-2xl shadow-sm">
                <CardHeader>
                  <CardTitle>Quick Actions</CardTitle>
                  <CardDescription>{settings.techCount} techs • {settings.payStructure} • ${settings.laborRate}/hr</CardDescription>
                </CardHeader>
                <CardContent className="space-y-3">
                  {settings.statuses.slice(0, 4).map((status) => (
                    <Button key={status} variant="outline" className="w-full justify-start rounded-2xl" onClick={() => updateOrderStatus(status)}>{status}</Button>
                  ))}
                  <Button variant="outline" className="w-full justify-start rounded-2xl" onClick={() => updateOrderStatus('Ready For Pickup')}><Receipt className="h-4 w-4 mr-2" />Mark Ready For Pickup</Button>
                  <Button className="w-full justify-start rounded-2xl" onClick={closeAndPayInvoice}><DollarSign className="h-4 w-4 mr-2" />Close & Mark Paid</Button>
                </CardContent>
              </Card>
            </div>

            {settings.productivityTracking && (
              <Card className="rounded-2xl shadow-sm mt-4">
                <CardHeader>
                  <CardTitle>Technician Productivity</CardTitle>
                  <CardDescription>Flag-hour performance snapshot for your current tech list.</CardDescription>
                </CardHeader>
                <CardContent>
                  <Table>
                    <TableHeader>
                      <TableRow>
                        <TableHead>Tech</TableHead>
                        <TableHead>ROs</TableHead>
                        <TableHead>Flagged Hours</TableHead>
                        <TableHead>Sales</TableHead>
                      </TableRow>
                    </TableHeader>
                    <TableBody>
                      {productivity.map((row) => (
                        <TableRow key={row.tech}>
                          <TableCell>{row.tech}</TableCell>
                          <TableCell>{row.ros}</TableCell>
                          <TableCell>{row.flaggedHours}</TableCell>
                          <TableCell>{currency(row.sales)}</TableCell>
